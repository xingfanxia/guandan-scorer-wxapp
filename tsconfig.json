{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "lib": ["ES2020"],
    "types": ["miniprogram-api-typings"],
    "skipLibCheck": true
  },
  "include": ["miniprogram/**/*.ts"]
}
