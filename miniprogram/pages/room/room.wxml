<view class="page {{themeClass}}">

  <view class="card empty" wx:if="{{!loaded && !loadError}}">连接房间 {{code}} …</view>
  <view class="card empty" wx:if="{{loadError}}">{{loadError}}</view>

  <block wx:if="{{loaded}}">
    <!-- 只读记分牌 -->
    <view class="card board">
      <view class="board__eyebrow {{vm.ended ? 'board__eyebrow--gold' : ''}}">{{vm.eyebrow}}</view>
      <view class="board__teams">
        <view class="board__team {{vm.roundOwner === 't1' ? 'board__team--owner' : ''}}">
          <text class="board__name board__name--t1">{{vm.teamNames.t1}}</text>
          <text class="board__level board__level--t1 {{vm.teamLevels.t1 === 'A' ? 'board__level--gold' : ''}}">{{vm.teamLevels.t1}}</text>
          <text class="board__afail" wx:if="{{vm.strictA && vm.teamLevels.t1 === 'A'}}">A失败 {{vm.aFail.t1}}/3</text>
        </view>
        <text class="board__vs">:</text>
        <view class="board__team {{vm.roundOwner === 't2' ? 'board__team--owner' : ''}}">
          <text class="board__name board__name--t2">{{vm.teamNames.t2}}</text>
          <text class="board__level board__level--t2 {{vm.teamLevels.t2 === 'A' ? 'board__level--gold' : ''}}">{{vm.teamLevels.t2}}</text>
          <text class="board__afail" wx:if="{{vm.strictA && vm.teamLevels.t2 === 'A'}}">A失败 {{vm.aFail.t2}}/3</text>
        </view>
      </view>
      <view class="room-meta">
        <text class="room-meta__code">房间 {{code}}</text>
        <text class="room-meta__channel">{{channelText}}</text>
      </view>
    </view>

    <!-- 红蓝队阵容 -->
    <view class="card section" wx:if="{{teamRoster.t1.length > 0 || teamRoster.t2.length > 0}}">
      <view class="section__title">阵容</view>
      <view class="roster">
        <view class="roster__team">
          <text class="roster__team-name roster__team-name--t1">{{vm.teamNames.t1}}</text>
          <view class="roster__members">
            <text class="roster__member" wx:for="{{teamRoster.t1}}" wx:for-item="p" wx:key="name">{{p.emoji}} {{p.name}}</text>
          </view>
        </view>
        <view class="roster__divider"></view>
        <view class="roster__team">
          <text class="roster__team-name roster__team-name--t2">{{vm.teamNames.t2}}</text>
          <view class="roster__members">
            <text class="roster__member" wx:for="{{teamRoster.t2}}" wx:for-item="p" wx:key="name">{{p.emoji}} {{p.name}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 结算与投票（比赛结束后出现） -->
    <view class="card section" wx:if="{{vm.ended}}">
      <view class="section__title">结算</view>
      <view class="mvp" wx:if="{{mvp}}">
        <text class="mvp__label">本场 MVP（最低平均排名）</text>
        <text class="mvp__name">{{mvp.emoji}} {{mvp.name}} · 平均 {{mvp.avg}}</text>
      </view>

      <view class="vote">
        <view class="vote__group">
          <text class="vote__label">投「最C」</text>
          <view class="vote__chips">
            <view
              wx:for="{{seats}}"
              wx:for-item="s"
              wx:key="id"
              class="chip {{voteMvp === s.id ? 'chip--picked' : ''}}"
              data-id="{{s.id}}"
              data-kind="mvp"
              bindtap="onPickVote"
            >{{s.emoji}} {{s.name}}<text wx:if="{{tally.mvp[s.id]}}" class="chip__count">{{tally.mvp[s.id]}}</text></view>
          </view>
        </view>
        <view class="vote__group">
          <text class="vote__label">投「最闹」</text>
          <view class="vote__chips">
            <view
              wx:for="{{seats}}"
              wx:for-item="s"
              wx:key="id"
              class="chip {{voteBurden === s.id ? 'chip--picked' : ''}}"
              data-id="{{s.id}}"
              data-kind="burden"
              bindtap="onPickVote"
            >{{s.emoji}} {{s.name}}<text wx:if="{{tally.burden[s.id]}}" class="chip__count">{{tally.burden[s.id]}}</text></view>
          </view>
        </view>
        <button
          class="btn btn--primary vote__submit"
          disabled="{{!voteMvp || !voteBurden}}"
          bindtap="onSubmitVote"
        >{{myVoted ? '改票' : '投票'}}</button>
        <text class="vote__total" wx:if="{{tally.total}}">已收 {{tally.total}} 票</text>
        <button
          wx:if="{{isOwner && tally.total}}"
          class="btn btn--ghost btn--danger vote__reset"
          bindtap="onResetVotes"
        >重新开票</button>
      </view>
    </view>

    <!-- 本场统计 -->
    <view class="card section stats" wx:if="{{stats && stats.rows.length > 0}}">
      <view class="section__title">本场统计 · {{stats.gamesInSession}} 局</view>
      <view class="stats__head">
        <text class="stats__cell stats__cell--name">玩家</text>
        <text class="stats__cell">平均</text>
        <text class="stats__cell">头游</text>
        <text class="stats__cell">垫底</text>
      </view>
      <view class="stats__row" wx:for="{{stats.rows}}" wx:for-item="r" wx:key="id">
        <text class="stats__cell stats__cell--name stats__cell--t{{r.team}}">{{r.emoji}} {{r.name}}</text>
        <text class="stats__cell stats__num">{{r.avg}}</text>
        <text class="stats__cell stats__num">{{r.first}}</text>
        <text class="stats__cell stats__num">{{r.last}}</text>
      </view>
      <block wx:if="{{stats.honorsUnlocked && stats.honorRows.length > 0}}">
        <view class="stats__honors-title">本场荣誉</view>
        <view class="honor-line" wx:for="{{stats.honorRows}}" wx:for-item="h" wx:key="title">
          <view class="honor-line__main">
            <text class="honor-line__title">{{h.title}}</text>
            <text class="honor-line__caption" wx:if="{{h.caption}}">{{h.caption}}</text>
          </view>
          <text class="honor-line__holder">{{h.emoji}} {{h.name}}</text>
        </view>
      </block>
      <view class="stats__honors-locked" wx:if="{{!stats.honorsUnlocked}}">本场荣誉满 5 局解锁 · 还差 {{5 - stats.gamesInSession}} 局</view>
    </view>

    <!-- 逐局记录 -->
    <view class="card section">
      <view class="section__title">逐局记录</view>
      <view class="empty" wx:if="{{rows.length === 0}}">还没开打 —— 等房主记第一局</view>
      <view class="row" wx:for="{{rows}}" wx:for-item="row" wx:key="seq">
        <view class="row__bar row__bar--{{row.winKey}}"></view>
        <view class="row__main">
          <view class="row__line">
            <text class="row__title">第 {{row.seq}} 局 · {{row.win}} {{row.combo}} → 打{{row.newLevel}}</text>
            <text class="row__up">+{{row.up}}</text>
          </view>
          <text class="row__ranks" wx:if="{{row.rankingLine}}">{{row.rankingLine}}</text>
          <text class="row__note" wx:if="{{row.aNote}}">{{row.aNote}}</text>
        </view>
      </view>
    </view>

    <button class="btn btn--secondary section" open-type="share">把房间发到群里</button>
  </block>

</view>
