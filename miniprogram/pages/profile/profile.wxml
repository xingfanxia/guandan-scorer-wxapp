<import src="../../templates/profileExtras.wxml" />
<view class="page {{themeClass}}">

  <view class="card empty" wx:if="{{loading}}">读取档案…</view>

  <view class="card empty" wx:if="{{!loading && !hasProfile}}">
    <view>还没有战绩 —— 在房间页认领座位，比赛结束后房主点「战绩入库」就有了</view>
    <button class="btn btn--secondary bind__btn" bindtap="onBindWeb">绑定 web 版玩家身份</button>
  </view>

  <view class="card section bind" wx:if="{{!loading && hasProfile && !boundHandle}}">
    <text class="bind__hint">打过 web 版（gd.ax0x.ai）？绑定后老战绩并进来</text>
    <button class="btn btn--secondary bind__btn" bindtap="onBindWeb">绑定 web 版玩家身份</button>
  </view>

  <block wx:if="{{!loading && hasProfile}}">
    <!-- 身份 -->
    <view class="card who">
      <image wx:if="{{avatarUrl}}" class="who__avatar" src="{{avatarUrl}}" />
      <view class="who__id">
        <text class="who__name">{{displayName || '无名牌手'}}</text>
        <text class="who__sub">{{summary.sessionsPlayed}} 场 · 胜率 {{summary.winRate}} · 天梯 {{summary.ladder}}{{boundHandle ? ' · @' + boundHandle : ''}}</text>
      </view>
    </view>

    <!-- 战绩 -->
    <view class="card section">
      <view class="section__title">战绩</view>
      <view class="stat-grid">
        <view class="stat" wx:for="{{statCells}}" wx:key="label">
          <text class="stat__num">{{item.value}}</text>
          <text class="stat__label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- 荣誉 -->
    <view class="card section" wx:if="{{honorRows.length > 0}}">
      <view class="section__title">荣誉</view>
      <view class="honor" wx:for="{{honorRows}}" wx:key="title">
        <view class="honor__main">
          <text class="honor__title">{{item.title}}</text>
          <text class="honor__caption" wx:if="{{item.caption}}">{{item.caption}}</text>
        </view>
        <text class="honor__count">×{{item.count}}</text>
      </view>
    </view>

    <!-- 成就 -->
    <view class="card section" wx:if="{{achievementRows.length > 0}}">
      <view class="section__title">成就 {{achievementRows.length}}/{{achievementTotal}}</view>
      <view class="ach" wx:for="{{achievementRows}}" wx:key="id">
        <text class="ach__badge">{{item.badge}}</text>
        <view class="ach__main">
          <text class="ach__name">{{item.name}}</text>
          <text class="ach__desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <!-- 队友与对手 / 近期排名走势 / 最近游戏（与玩家查询页共用模板） -->
    <template is="profileExtras" data="{{relations, rankTrend, recentGames}}" />
  </block>

</view>
