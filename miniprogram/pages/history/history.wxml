<view class="page">
  <view class="empty card" wx:if="{{rows.length === 0}}">
    还没有记录 —— 回主页记一局就有了
  </view>

  <view class="card row" wx:for="{{rows}}" wx:for-item="row" wx:key="seq">
    <view class="row__bar row__bar--{{row.winKey}}"></view>
    <view class="row__main">
      <view class="row__line">
        <text class="row__title">第 {{row.seq}} 局 · {{row.win}} {{row.combo}} → 打{{row.newLevel}}</text>
        <text class="row__up">+{{row.up}}</text>
      </view>
      <text class="row__note" wx:if="{{row.aNote}}">{{row.aNote}}</text>
      <view class="row__meta">
        <text class="row__ts">{{row.ts}}</text>
        <text
          wx:if="{{row.isLatest}}"
          class="row__undo"
          bindtap="onUndoLatest"
        >撤销此局</text>
      </view>
    </view>
  </view>
</view>
