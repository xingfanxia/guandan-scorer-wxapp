/* 主计分页 — 公共 .card/.btn/.board 在 app.wxss；此处只留页面专属 */

.section {
  margin-top: var(--s3);
}

/* 离屏画布：显示尺寸无所谓（导出走 backing store，由 onSavePoster 按布局动态设置） */
.poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: 0;
  width: 600px;
  height: 800px;
}

/* 微信原生 button 默认定宽会把长文案裁成「战绩入库（认领」—— 全宽展开（同 players 页 .lad__back 范式） */
.board__advance {
  width: 100%;
}

.board__mvp {
  margin-top: var(--s3);
  font-size: var(--font-body);
  color: var(--gold-a);
  font-weight: 600;
  text-align: center;
}

/* ===== 模式与规则 ===== */
.seg {
  display: flex;
  background: var(--surface-2);
  border-radius: var(--radius-control);
  padding: 4rpx;
}

.seg__item {
  flex: 1;
  text-align: center;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 10rpx;
  font-size: var(--font-body);
  color: var(--text-secondary);
}

.seg__item--active {
  background: var(--surface);
  color: var(--text-primary);
  font-weight: 600;
  border: 1rpx solid var(--hairline);
}

.pref {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: var(--touch-min);
  border-top: 1rpx solid var(--hairline);
  margin-top: var(--s2);
  padding-top: var(--s1);
}

.pref__label {
  font-size: var(--font-body);
}

/* 外观开关行：标签在上、整宽 seg 在下（区别于 .pref 的左右布局；复用 .seg 段控件） */
.pref--stack {
  flex-direction: column;
  align-items: stretch;
  gap: var(--s2);
}

.seg--theme .seg__item {
  font-size: var(--font-label);
}

/* ===== 围观分享 ===== */
.share {
  display: flex;
  flex-direction: column;
  gap: var(--s3);
}

.share__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.share__watch {
  width: 100%;
  height: var(--touch-min);
  line-height: var(--touch-min);
  font-size: var(--font-body);
}

.share__code {
  font-size: var(--font-title);
  font-weight: 700;
  font-feature-settings: "tnum";
  letter-spacing: 4rpx;
}

.share__hint {
  font-size: var(--font-label);
  color: var(--text-secondary);
  margin-top: var(--s1);
}

.share__btn {
  flex: 0 0 auto;
  height: var(--touch-min);
  line-height: var(--touch-min);
  font-size: var(--font-body);
}

/* ===== 玩家与名次 ===== */
.section__head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: var(--s2);
}

.section__title {
  font-size: var(--font-title);
  font-weight: 600;
}

.section__hint {
  font-size: var(--font-label);
  color: var(--text-secondary);
}

.section__shuffle {
  font-size: var(--font-label);
  color: var(--accent);
  font-weight: 600;
  padding: var(--s1) var(--s2);
}

.team-row {
  display: flex;
  align-items: flex-start;
  margin-top: var(--s2);
}

.team-row__bar {
  width: 6rpx;
  align-self: stretch;
  border-radius: var(--radius-pill);
  margin-right: var(--s2);
}

.team-row__bar--t1 { background: var(--team-t1); }
.team-row__bar--t2 { background: var(--team-t2); }

.team-row__chips {
  display: flex;
  flex-wrap: wrap;
  gap: var(--s2);
  flex: 1;
}

.chip {
  display: flex;
  align-items: center;
  height: var(--touch-min);
  padding: 0 var(--s3);
  border: 1rpx solid var(--hairline);
  border-radius: var(--radius-pill);
  background: var(--surface);
  position: relative;
}

.chip--t1.chip--ranked { background: var(--team-t1-soft); border-color: var(--team-t1); }
.chip--t2.chip--ranked { background: var(--team-t2-soft); border-color: var(--team-t2); }

.chip__badge {
  position: absolute;
  top: -14rpx;
  left: -8rpx;
  min-width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: var(--radius-pill);
  background: var(--accent);
  color: var(--on-accent);
  font-size: var(--font-label);
  font-weight: 600;
  font-feature-settings: "tnum";
}

.chip__emoji {
  font-size: var(--font-body);
  margin-right: var(--s1);
}

.chip__name {
  font-size: var(--font-body);
  max-width: 8em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chip--add {
  color: var(--accent);
  border-style: dashed;
}

.chip--loading {
  color: var(--text-secondary);
  opacity: 0.7;
}

.empty {
  margin-top: var(--s3);
  font-size: var(--font-label);
}

/* ===== 升级预览条 ===== */
.preview {
  margin-top: var(--s3);
  display: flex;
  align-items: baseline;
  gap: var(--s3);
  border-color: var(--accent);
}

.preview__num {
  font-size: var(--font-num-lg);
  font-weight: 700;
  color: var(--accent);
  font-feature-settings: "tnum";
}

.preview__detail {
  font-size: var(--font-body);
  color: var(--text-secondary);
}

/* 两行两列：4 字按钮（对局历史/我的档案/玩家天梯/围观别人）一行四个会被截断 */
.nav {
  display: flex;
  flex-wrap: wrap;
  gap: var(--s2);
}

.nav__btn {
  flex: 0 1 calc((100% - var(--s2)) / 2);
  height: var(--touch-min);
  line-height: var(--touch-min);
  font-size: var(--font-body);
  background: var(--surface);
}

/* ===== 底部操作栏 ===== */
.bar-spacer {
  height: 160rpx;
}

.actionbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: var(--s2);
  padding: var(--s2) var(--gutter);
  padding-bottom: calc(var(--s2) + env(safe-area-inset-bottom));
  background: var(--surface);
  border-top: 1rpx solid var(--hairline);
  box-shadow: var(--bar-shadow);
}

/* 微信 button 自带默认宽度 —— 操作栏内 ghost 按钮定宽，主按钮吃满剩余 */
.actionbar .btn--ghost {
  flex: 0 0 176rpx;
  width: 176rpx;
  min-width: 0;
  padding: 0;
}

.actionbar .actionbar__apply {
  flex: 1;
  width: auto;
}

/* ===== 底部弹层（选人 / 重置，页面内自定义，替代原生 actionSheet/modal） ===== */
.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.18s;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.sheet-mask--on {
  visibility: visible;
  opacity: 1;
}

.sheet {
  background: var(--surface);
  border-radius: var(--radius-card) var(--radius-card) 0 0;
  padding: var(--s3) var(--gutter);
  padding-bottom: calc(var(--s3) + env(safe-area-inset-bottom));
  max-height: 78vh;
  display: flex;
  flex-direction: column;
}

.sheet__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--s2);
}

.sheet__title {
  font-size: var(--font-title);
  font-weight: 700;
}

.sheet__close {
  font-size: var(--font-body);
  color: var(--text-secondary);
  padding: var(--s1) var(--s2);
}

.sheet__scroll {
  max-height: 52vh;
}

.sheet__empty {
  padding: var(--s4) 0;
  text-align: center;
  font-size: var(--font-label);
  color: var(--text-secondary);
}

.pool-item {
  display: flex;
  align-items: center;
  gap: var(--s2);
  min-height: var(--touch-min);
  padding: var(--s2) var(--s2);
  border-radius: var(--radius-control);
  border: 1rpx solid transparent;
}

.pool-item + .pool-item {
  border-top: 1rpx solid var(--hairline);
}

.pool-item--on {
  background: var(--surface-2);
  border-color: var(--accent);
}

.pool-item__emoji {
  font-size: var(--font-title);
}

.pool-item__main {
  flex: 1;
  min-width: 0;
}

.pool-item__name {
  display: block;
  font-size: var(--font-body);
  font-weight: 600;
}

.pool-item__sub {
  display: block;
  font-size: var(--font-label);
  color: var(--text-secondary);
}

.pool-item__check {
  font-size: var(--font-title);
  color: var(--accent);
  font-weight: 700;
  width: 48rpx;
  text-align: center;
}

.sheet__foot {
  display: flex;
  gap: var(--s2);
  margin-top: var(--s3);
}

.sheet__manual {
  flex: 0 0 200rpx;
  width: 200rpx;
  height: var(--touch-min);
  line-height: var(--touch-min);
  font-size: var(--font-body);
}

.sheet__confirm {
  flex: 1;
  width: auto;
  height: var(--touch-min);
  line-height: var(--touch-min);
  font-size: var(--font-body);
}

/* 重置弹层条目 */
.reset-item {
  padding: var(--s3) var(--s2);
  border-radius: var(--radius-control);
}

.reset-item + .reset-item {
  border-top: 1rpx solid var(--hairline);
}

.reset-item:active {
  background: var(--surface-2);
}

.reset-item__main {
  display: block;
  font-size: var(--font-body);
  font-weight: 600;
}

.reset-item__sub {
  display: block;
  margin-top: 4rpx;
  font-size: var(--font-label);
  color: var(--text-secondary);
}

.reset-cancel {
  margin-top: var(--s2);
  padding: var(--s3) 0;
  text-align: center;
  font-size: var(--font-body);
  color: var(--text-secondary);
  border-top: 1rpx solid var(--hairline);
}

/* 选人弹层去向切换段 */
.sheet__seg {
  display: flex;
  gap: var(--s1);
  background: var(--surface-2);
  border-radius: var(--radius-control);
  padding: 4rpx;
  margin-bottom: var(--s2);
}

.sheet__seg-item {
  flex: 1;
  text-align: center;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 10rpx;
  font-size: var(--font-label);
  color: var(--text-secondary);
}

.sheet__seg-item--on {
  background: var(--surface);
  color: var(--text-primary);
  font-weight: 600;
  border: 1rpx solid var(--hairline);
}

.sheet__seg-item--t1.sheet__seg-item--on { color: var(--team-t1); }
.sheet__seg-item--t2.sheet__seg-item--on { color: var(--team-t2); }
