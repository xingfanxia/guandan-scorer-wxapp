<view class="page index {{themeClass}}">

  <!-- 级牌记分牌（签名元素，DESIGN.md §5） -->
  <view class="card board">
    <view class="board__eyebrow {{ended ? 'board__eyebrow--gold' : ''}}">{{eyebrow}}</view>
    <view class="board__teams">
      <view class="board__team {{roundOwner === 't1' ? 'board__team--owner' : ''}}">
        <text class="board__name board__name--t1">{{teamNames.t1}}</text>
        <text class="board__level board__level--t1 {{teamLevels.t1 === 'A' ? 'board__level--gold' : ''}}">{{teamLevels.t1}}</text>
        <text class="board__afail" wx:if="{{prefs.strictA && teamLevels.t1 === 'A'}}">A失败 {{aFail.t1}}/3</text>
      </view>
      <text class="board__vs">:</text>
      <view class="board__team {{roundOwner === 't2' ? 'board__team--owner' : ''}}">
        <text class="board__name board__name--t2">{{teamNames.t2}}</text>
        <text class="board__level board__level--t2 {{teamLevels.t2 === 'A' ? 'board__level--gold' : ''}}">{{teamLevels.t2}}</text>
        <text class="board__afail" wx:if="{{prefs.strictA && teamLevels.t2 === 'A'}}">A失败 {{aFail.t2}}/3</text>
      </view>
    </view>
    <button
      wx:if="{{nextRoundBase}}"
      class="btn btn--secondary board__advance"
      hover-class="btn--pressed"
      bindtap="onAdvance"
    >进入下一局（打{{nextRoundBase}}）</button>
    <view class="board__mvp" wx:if="{{ended && mvpText}}">{{mvpText}}</view>
    <button
      wx:if="{{ended && roomCode}}"
      class="btn btn--secondary board__advance"
      hover-class="btn--pressed"
      bindtap="onSyncProfiles"
    >战绩入库（认领过座位的玩家）</button>
    <button
      wx:if="{{ended}}"
      class="btn btn--secondary board__advance"
      hover-class="btn--pressed"
      bindtap="onSavePoster"
    >生成战绩海报存相册</button>
  </view>

  <!-- 海报离屏画布 -->
  <canvas type="2d" id="posterCanvas" class="poster-canvas"></canvas>

  <!-- 围观分享 -->
  <view class="card section share">
    <view class="share__row">
      <view>
        <view class="share__code">{{roomCode || '围观'}}</view>
        <view class="share__hint">{{roomCode ? '群里发卡片，牌友点开即看实时比分' : '开围观生成房间码，牌友实时看分'}}</view>
      </view>
      <button wx:if="{{roomCode}}" class="btn btn--secondary share__btn" open-type="share">发到群里</button>
      <button wx:else class="btn btn--secondary share__btn" bindtap="onOpenRoom">开围观</button>
    </view>
    <!-- 围观别人：常驻显眼入口（房主以外的牌友进别人的房间看分） -->
    <button class="btn btn--primary share__watch" bindtap="onEnterRoomCode">🔭 围观别人的房间 · 输房间码</button>
  </view>

  <!-- 模式与规则 -->
  <view class="card section">
    <view class="seg">
      <view
        wx:for="{{modeOptions}}"
        wx:key="*this"
        class="seg__item {{mode === item ? 'seg__item--active' : ''}}"
        data-mode="{{item}}"
        bindtap="onMode"
      >{{item}}人</view>
    </view>
    <view class="pref">
      <text class="pref__label">严格A级（3次失败回2）</text>
      <switch checked="{{prefs.strictA}}" color="{{accentColor}}" data-key="strictA" bindchange="onPref" />
    </view>
    <view class="pref">
      <text class="pref__label">升级需含头游</text>
      <switch checked="{{prefs.must1}}" color="{{accentColor}}" data-key="must1" bindchange="onPref" />
    </view>
    <view class="pref">
      <text class="pref__label">记分后自动进下一局</text>
      <switch checked="{{prefs.autoNext}}" color="{{accentColor}}" data-key="autoNext" bindchange="onPref" />
    </view>
    <view class="pref pref--stack">
      <text class="pref__label">深色外观</text>
      <view class="seg seg--theme">
        <view class="seg__item {{themePref === 'auto' ? 'seg__item--active' : ''}}" data-pref="auto" bindtap="onThemePick">跟随系统</view>
        <view class="seg__item {{themePref === 'light' ? 'seg__item--active' : ''}}" data-pref="light" bindtap="onThemePick">浅色</view>
        <view class="seg__item {{themePref === 'dark' ? 'seg__item--active' : ''}}" data-pref="dark" bindtap="onThemePick">深色</view>
      </view>
    </view>
  </view>

  <!-- 玩家与名次录入 -->
  <view class="card section">
    <view class="section__head">
      <text class="section__title">玩家</text>
      <text class="section__hint" wx:if="{{rankHint}}">{{rankHint}}</text>
      <text class="section__shuffle" wx:if="{{playersCount >= 2}}" bindtap="onShuffleTeams">随机分队</text>
    </view>

    <view class="team-row" wx:for="{{teamRows}}" wx:for-item="row" wx:key="key">
      <view class="team-row__bar team-row__bar--{{row.key}}"></view>
      <view class="team-row__chips">
        <view
          wx:for="{{row.players}}"
          wx:for-item="p"
          wx:key="id"
          class="chip chip--{{row.key}} {{p.badge ? 'chip--ranked' : ''}}"
          data-id="{{p.id}}"
          bindtap="onTapPlayer"
          bindlongpress="onEditPlayer"
        >
          <text class="chip__badge" wx:if="{{p.badge}}">{{p.badge}}</text>
          <text class="chip__emoji">{{p.emoji}}</text>
          <text class="chip__name">{{p.name}}</text>
        </view>
        <view
          wx:if="{{playersCount < modeNum}}"
          class="chip chip--add {{addingTeam === row.team ? 'chip--loading' : ''}}"
          data-team="{{row.team}}"
          bindtap="onAddPlayer"
        >{{addingTeam === row.team ? '读取中…' : '＋ 加人'}}</view>
      </view>
    </view>

    <view class="empty" wx:if="{{playersCount < modeNum}}">
      加满 {{modeNum}} 人就能开局（还差 {{modeNum - playersCount}} 人）
    </view>
  </view>

  <!-- 升级预览条 -->
  <view class="card preview" wx:if="{{preview}}">
    <text class="preview__num">{{preview.upgradeText}}</text>
    <text class="preview__detail">{{preview.detail}}</text>
  </view>

  <!-- 页面导航 -->
  <view class="nav section">
    <button class="btn btn--ghost nav__btn" hover-class="btn--pressed" bindtap="goHistory">对局历史</button>
    <button class="btn btn--ghost nav__btn" hover-class="btn--pressed" bindtap="goProfile">我的档案</button>
    <button class="btn btn--ghost nav__btn" hover-class="btn--pressed" bindtap="goPlayers">玩家天梯</button>
    <button wx:if="{{roomCode}}" class="btn btn--ghost nav__btn" hover-class="btn--pressed" bindtap="goRoom">进我的房间</button>
  </view>

  <view class="bar-spacer"></view>

  <!-- 底部操作栏 -->
  <view class="actionbar">
    <button class="btn btn--ghost" hover-class="btn--pressed" bindtap="onUndo">撤销</button>
    <button class="btn btn--ghost btn--danger" hover-class="btn--pressed" bindtap="onReset">重置</button>
    <button
      class="btn btn--primary actionbar__apply"
      hover-class="btn--pressed"
      disabled="{{!preview}}"
      bindtap="onApply"
    >应用结果</button>
  </view>

  <!-- 选人弹层（页面内自定义，一屏滚动全员 + 多选一次加入） -->
  <view class="sheet-mask {{poolSheet.show ? 'sheet-mask--on' : ''}}" catchtap="onPoolClose">
    <view class="sheet" catchtap="noop">
      <view class="sheet__head">
        <text class="sheet__title">选牌友加入</text>
        <text class="sheet__close" catchtap="onPoolClose">关闭</text>
      </view>
      <view class="sheet__seg">
        <view class="sheet__seg-item {{poolSheet.target === 0 ? 'sheet__seg-item--on' : ''}}" data-target="0" catchtap="onPoolTarget">随机分队</view>
        <view class="sheet__seg-item sheet__seg-item--t1 {{poolSheet.target === 1 ? 'sheet__seg-item--on' : ''}}" data-target="1" catchtap="onPoolTarget">蓝队</view>
        <view class="sheet__seg-item sheet__seg-item--t2 {{poolSheet.target === 2 ? 'sheet__seg-item--on' : ''}}" data-target="2" catchtap="onPoolTarget">红队</view>
      </view>
      <scroll-view scroll-y class="sheet__scroll" wx:if="{{poolSheet.rows.length > 0}}">
        <view
          wx:for="{{poolSheet.rows}}"
          wx:for-item="r"
          wx:key="handle"
          class="pool-item {{r.selected ? 'pool-item--on' : ''}}"
          data-idx="{{index}}"
          catchtap="onPoolToggle"
        >
          <text class="pool-item__emoji">{{r.emoji}}</text>
          <view class="pool-item__main">
            <text class="pool-item__name">{{r.displayName}}</text>
            <text class="pool-item__sub">@{{r.handle}} · {{r.sub}}</text>
          </view>
          <text class="pool-item__check">{{r.selected ? '✓' : ''}}</text>
        </view>
      </scroll-view>
      <view class="sheet__empty" wx:else>玩家池为空（或都已上场）—— 手动输入加人</view>
      <view class="sheet__foot">
        <button class="btn btn--ghost sheet__manual" catchtap="onPoolManual">手动输入</button>
        <button
          class="btn btn--primary sheet__confirm"
          disabled="{{poolSheet.selectedCount === 0}}"
          catchtap="onPoolConfirm"
        >加入{{poolSheet.selectedCount > 0 ? ' ' + poolSheet.selectedCount + ' 人' : ''}}</button>
      </view>
    </view>
  </view>

  <!-- 重置弹层（页面内自定义，替代原生 actionSheet+modal） -->
  <view class="sheet-mask {{resetSheet ? 'sheet-mask--on' : ''}}" catchtap="onResetPick" data-mode="cancel">
    <view class="sheet" catchtap="noop">
      <view class="sheet__head">
        <text class="sheet__title">重新开始</text>
      </view>
      <view class="reset-item" catchtap="onResetPick" data-mode="keep">
        <text class="reset-item__main">重新开一局</text>
        <text class="reset-item__sub">保留玩家，比分清零继续打 · 围观房间不变</text>
      </view>
      <view class="reset-item" catchtap="onResetPick" data-mode="clear">
        <text class="reset-item__main">清空玩家重来</text>
        <text class="reset-item__sub">玩家、比分、历史全部清空 · 开新围观房间</text>
      </view>
      <view class="reset-cancel" catchtap="onResetPick" data-mode="cancel">取消</view>
    </view>
  </view>

</view>
