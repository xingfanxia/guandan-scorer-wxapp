<view class="page">

  <view class="card empty" wx:if="{{loading}}">读取玩家池…</view>
  <view class="card empty" wx:if="{{!loading && rows.length === 0}}">
    玩家池是空的 —— 等房主导入 web 版玩家
  </view>

  <!-- 读取详情时整列表让位给 loading 态（点击反馈 + 防重复点） -->
  <view class="card empty" wx:if="{{detailLoading}}">读取档案…</view>

  <!-- 天梯榜列表 -->
  <view class="card" wx:if="{{!loading && rows.length > 0 && !detail && !detailLoading}}">
    <view class="lad__head">
      <text class="lad__cell lad__cell--rank">#</text>
      <text class="lad__cell lad__cell--name">玩家</text>
      <text class="lad__cell">天梯</text>
      <text class="lad__cell">场次</text>
    </view>
    <view
      class="lad__row {{p.calibrated ? '' : 'lad__row--prov'}}"
      wx:for="{{rows}}"
      wx:for-item="p"
      wx:key="handle"
      hover-class="lad__row--pressed"
      data-handle="{{p.handle}}"
      bindtap="onTapPlayer"
    >
      <text class="lad__cell lad__cell--rank {{p.calibrated ? '' : 'lad__cell--prov'}}">{{p.rankText}}</text>
      <view class="lad__cell lad__cell--name">
        <text class="lad__name">{{p.emoji}} {{p.displayName}}{{p.boundToMe ? '（我）' : ''}}</text>
        <text class="lad__handle">@{{p.handle}}{{p.bound ? '' : ' · 未绑定'}}{{p.calibrated ? '' : ' · 还差 ' + p.calibrationLeft + ' 场'}}</text>
      </view>
      <text class="lad__cell lad__num">{{p.ladderText}}</text>
      <text class="lad__cell lad__num">{{p.totalSessions}}</text>
    </view>
    <view class="lad__hint">累计 3 场（web + 小程序）进正式榜，新人待校准暂列底部 · 带 * 为 web 历史折算起评分，打小程序天梯局后实结</view>
  </view>

  <!-- 玩家详情 -->
  <block wx:if="{{detail && !detailLoading}}">
    <view class="card who">
      <view class="who__id">
        <text class="who__name">{{detail.emoji}} {{detail.displayName}}</text>
        <text class="who__sub">@{{detail.handle}}{{detail.tagline ? ' · ' + detail.tagline : ''}}</text>
        <text class="who__sub" wx:if="{{detail.summary}}">{{detail.webSource ? 'web 历史' : '综合'}} {{detail.summary.sessionsPlayed}} 场 · 胜率 {{detail.summary.winRate}} · 天梯 {{detail.summary.ladder}}{{detail.seeded ? '（起评分）' : ''}}</text>
        <text class="who__sub" wx:if="{{detail.summary && detail.webSource}}">未绑定微信 —— 展示的是 web 版战绩，本人绑定后并入小程序</text>
        <text class="who__sub" wx:if="{{detail.webFetchFailed}}">未绑定微信 · 完整战绩暂时拉取失败，仅显示 web 概要</text>
        <text class="who__sub" wx:if="{{!detail.summary && !detail.webFetchFailed}}">还没有战绩</text>
      </view>
    </view>

    <view class="card section" wx:if="{{detail.statCells.length > 0}}">
      <view class="section__title">{{detail.webSource ? 'web 版战绩' : '综合战绩'}}</view>
      <view class="stat-grid">
        <view class="stat" wx:for="{{detail.statCells}}" wx:key="label">
          <text class="stat__num">{{item.value}}</text>
          <text class="stat__label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="card section" wx:if="{{detail.honorRows.length > 0}}">
      <view class="section__title">荣誉</view>
      <view class="honor" wx:for="{{detail.honorRows}}" wx:key="title">
        <view class="honor__main">
          <text class="honor__title">{{item.title}}</text>
          <text class="honor__caption" wx:if="{{item.caption}}">{{item.caption}}</text>
        </view>
        <text class="honor__count">×{{item.count}}</text>
      </view>
    </view>

    <view class="card section" wx:if="{{detail.achievementRows.length > 0}}">
      <view class="section__title">成就 {{detail.achievementRows.length}}/{{detail.achievementTotal}}</view>
      <view class="ach" wx:for="{{detail.achievementRows}}" wx:key="id">
        <text class="ach__badge">{{item.badge}}</text>
        <view class="ach__main">
          <text class="ach__name">{{item.name}}</text>
          <text class="ach__desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <!-- web 老战绩概要：已绑定玩家单列原始 web（上方综合战绩已并入）；
         未绑定且富战绩拉取失败时也回退到这 3 格概要（不编造富档案）。
         未绑定且拉取成功时上方整块已是 web 战绩，不重复。 -->
    <view class="card section" wx:if="{{detail.bound || detail.webFetchFailed}}">
      <view class="section__title">{{detail.bound ? 'web 版老战绩' : 'web 版战绩（概要）'}}</view>
      <view class="stat-grid">
        <view class="stat" wx:for="{{detail.webCells}}" wx:key="label">
          <text class="stat__num">{{item.value}}</text>
          <text class="stat__label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <button class="btn btn--secondary lad__back" hover-class="btn--pressed" bindtap="onCloseDetail">返回天梯榜</button>
  </block>

</view>
