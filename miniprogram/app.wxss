@import "styles/tokens.wxss";

page {
  background: var(--bg);
  color: var(--text-primary);
  font-size: var(--font-body);
  font-family: -apple-system, "PingFang SC", "HarmonyOS Sans SC", "MiSans", sans-serif;
}

.page {
  /* 铺满视口并自绘主题底色：手动外观覆盖时（.page 带 theme-- 类重定义 --bg）盖住
     身后系统主题的 page{} 元素，避免边缘/回弹露出系统色 */
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--bg);
  /* 关键：默认文字色必须在 .page 作用域解析 —— 否则普通 <text> 继承 page{} 元素上
     按系统 @media 算好的 color（手动覆盖时与背景反色 → 看不清）。.page 带 theme-- 类时
     这里的 var() 在覆盖后的 token 上重算，继承色才跟着主题走。 */
  color: var(--text-primary);
  padding: var(--gutter);
}

/* ===== 公共组件（index / room / history 共用） ===== */

.card {
  background: var(--surface);
  border: 1rpx solid var(--hairline);
  border-radius: var(--radius-card);
  padding: var(--s4);
}

.btn {
  height: var(--touch-bar);
  line-height: var(--touch-bar);
  border-radius: var(--radius-control);
  font-size: var(--font-title);
  font-weight: 600;
  padding: 0 var(--s3);
  margin: 0;
  background: transparent;
  color: var(--text-primary);
  border: 1rpx solid var(--hairline);
}

.btn::after {
  border: none;
}

.btn--primary {
  background: var(--accent);
  color: var(--on-accent);
  border: none;
  flex: 1;
}

.btn--primary[disabled] {
  opacity: 0.4;
  color: var(--on-accent);
  background: var(--accent);
}

.btn--ghost {
  background: transparent;
}

.btn--danger {
  color: var(--danger);
}

.btn--secondary {
  background: transparent;
  color: var(--accent);
  border: 1rpx solid var(--accent);
}

.btn--pressed {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ===== 级牌记分牌（DESIGN.md §5 签名元素） ===== */

.board__eyebrow {
  font-size: var(--font-label);
  font-weight: 500;
  letter-spacing: 2rpx;
  color: var(--accent);
}

.board__eyebrow--gold {
  color: var(--gold-a);
}

.board__teams {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-top: var(--s2);
}

.board__team {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 200rpx;
  padding-bottom: var(--s1);
  border-bottom: 4rpx solid transparent;
}

.board__team--owner {
  border-bottom-color: var(--accent);
}

.board__name {
  font-size: var(--font-label);
  font-weight: 500;
}

.board__name--t1 { color: var(--team-t1); }
.board__name--t2 { color: var(--team-t2); }

.board__level {
  font-size: var(--font-level);
  font-weight: 800;
  line-height: 1;
  font-feature-settings: "tnum";
}

.board__level--t1 { color: var(--team-t1); }
.board__level--t2 { color: var(--team-t2); }
.board__level--gold { color: var(--gold-a); }

.board__vs {
  font-size: var(--font-num-lg);
  font-weight: 700;
  color: var(--text-secondary);
}

.board__afail {
  font-size: var(--font-label);
  color: var(--text-secondary);
  margin-top: var(--s1);
}

.board__advance {
  margin-top: var(--s3);
}

/* ===== 历史行（history / room 共用） ===== */

.row {
  display: flex;
  margin-bottom: var(--s2);
}

.row__bar {
  width: 6rpx;
  border-radius: var(--radius-pill);
  margin-right: var(--s3);
  align-self: stretch;
}

.row__bar--t1 { background: var(--team-t1); }
.row__bar--t2 { background: var(--team-t2); }

.row__main {
  flex: 1;
}

.row__line {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.row__title {
  font-size: var(--font-body);
  font-weight: 600;
  font-feature-settings: "tnum";
}

.row__up {
  font-size: var(--font-body);
  font-weight: 700;
  color: var(--accent);
  font-feature-settings: "tnum";
}

.row__ranks {
  display: block;
  margin-top: var(--s1);
  font-size: var(--font-label);
  color: var(--text-secondary);
  font-feature-settings: "tnum";
}

.row__note {
  display: block;
  margin-top: var(--s1);
  font-size: var(--font-label);
  color: var(--text-secondary);
}

.row__meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: var(--s1);
}

.row__ts {
  font-size: var(--font-label);
  color: var(--text-secondary);
  font-feature-settings: "tnum";
}

.empty {
  color: var(--text-secondary);
  font-size: var(--font-body);
}

/* ===== 队友与对手（profile / players 共用，templates/profileExtras.wxml） ===== */

.rels {
  display: flex;
  gap: var(--s3);
}

.rels__col {
  flex: 1;
  min-width: 0;
}

.rels__coltitle {
  font-size: var(--font-label);
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 1rpx;
  margin-bottom: var(--s2);
}

.rels__empty {
  font-size: var(--font-label);
  color: var(--text-secondary);
}

.relrow {
  display: flex;
  align-items: center;
  margin-bottom: var(--s2);
}

.relrow__emoji {
  font-size: 40rpx;
  margin-right: var(--s2);
}

.relrow__body {
  flex: 1;
  min-width: 0;
}

.relrow__name {
  display: block;
  font-size: var(--font-body);
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.relrow__label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.relrow__barwrap {
  width: 150rpx;
  flex: none;
  text-align: right;
}

.relrow__pct {
  font-size: var(--font-label);
  font-weight: 700;
  font-feature-settings: "tnum";
}

.relrow__bar {
  height: 8rpx;
  margin-top: 6rpx;
  border-radius: var(--radius-pill);
  background: var(--surface-2);
  overflow: hidden;
}

.relrow__fill {
  height: 100%;
  border-radius: var(--radius-pill);
}

.relrow__fill--win { background: var(--accent); }
.relrow__fill--loss { background: var(--danger); }

.rels__alltitle {
  margin-top: var(--s4);
  margin-bottom: var(--s2);
  font-size: var(--font-label);
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 1rpx;
}

.relbar {
  display: flex;
  align-items: center;
  margin-bottom: var(--s2);
}

.relbar__name {
  width: 180rpx;
  flex: none;
  font-size: var(--font-label);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.relbar__track {
  flex: 1;
  height: 16rpx;
  margin: 0 var(--s2);
  border-radius: var(--radius-pill);
  background: var(--surface-2);
  overflow: hidden;
}

.relbar__fill {
  height: 100%;
  border-radius: var(--radius-pill);
}

.relbar__fill--win { background: var(--accent); }
.relbar__fill--mid { background: var(--team-t1); }
.relbar__fill--loss { background: var(--danger); }

.relbar__pct {
  width: 80rpx;
  flex: none;
  text-align: right;
  font-size: var(--font-label);
  font-weight: 700;
  font-feature-settings: "tnum";
}

/* ===== 近期排名走势 canvas ===== */

.rankchart {
  width: 100%;
  height: 360rpx;
  display: block;
}

.rankchart__hint {
  display: block;
  margin-top: var(--s1);
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ===== 最近游戏 ===== */

.rg {
  display: flex;
  align-items: center;
  margin-bottom: var(--s2);
}

.rg__res {
  width: 48rpx;
  height: 48rpx;
  flex: none;
  border-radius: var(--radius-pill);
  margin-right: var(--s3);
  text-align: center;
  line-height: 48rpx;
  font-size: var(--font-label);
  font-weight: 700;
  color: var(--on-accent);
}

.rg__res--win { background: var(--accent); }
.rg__res--loss { background: var(--danger); }

.rg__main {
  flex: 1;
  min-width: 0;
}

.rg__line {
  display: block;
  font-size: var(--font-body);
  font-feature-settings: "tnum";
}

.rg__honors {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--gold-a);
}

.rg__date {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-feature-settings: "tnum";
}

/* 管理入口（档案页底部，克制） */
.admin-entry {
  margin: var(--s4) auto var(--s2);
  text-align: center;
  font-size: 22rpx;
  color: var(--text-secondary);
  opacity: 0.7;
}
